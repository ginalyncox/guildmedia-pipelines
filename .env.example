# --- Zoom: jward account ---
ZOOM_JWARD_ACCOUNT_ID=
ZOOM_JWARD_CLIENT_ID=
ZOOM_JWARD_CLIENT_SECRET=
# Optional hourly fallback if S2S creds are being refreshed:
# ZOOM_JWARD_ACCESS_TOKEN=
ZOOM_JWARD_WEBHOOK_SECRET=

# --- Zoom: navigators account ---
ZOOM_NAVIGATORS_ACCOUNT_ID=
ZOOM_NAVIGATORS_CLIENT_ID=
ZOOM_NAVIGATORS_CLIENT_SECRET=
# ZOOM_NAVIGATORS_ACCESS_TOKEN=
ZOOM_NAVIGATORS_WEBHOOK_SECRET=

# Optional legacy fallback (expires hourly — not recommended for production)
# ZOOM_ACCESS_TOKEN=

# --- YouTube ---
YOUTUBE_PLAYLIST_NAME=Replays
YOUTUBE_CHANNEL_ID=
# Optional cloud/.env-only auth (paste full JSON — no separate files needed):
# YOUTUBE_TOKEN_JSON={"token":"...","refresh_token":"...","client_id":"..."}
# GOOGLE_CLIENT_SECRETS_JSON={"installed":{"client_id":"...","client_secret":"..."}}
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- WordPress ---
WP_BASE_URL=https://ganjierguild.com
WP_USER=
WP_APP_PASSWORD=
WP_REPLAY_CPT=replay

# --- Canva ---
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://127.0.0.1:8080/canva/callback
CANVA_THUMBNAIL_FOLDER_NAME=Replay Thumbnail Folder
# Optional fallback if the folder name changes or name lookup is unavailable:
# CANVA_THUMBNAIL_FOLDER_ID=
# CANVA_TOKEN_JSON={"access_token":"...","refresh_token":"..."}

# --- Backfill / poll ---
BACKFILL_FROM_DATE=2023-01-01
BACKFILL_TOPIC_FILTER=
BACKFILL_DELAY_SECONDS=5
POLL_LOOKBACK_HOURS=48

# --- Replay tracker (WordPress dashboard is default) ---
REPLAY_TRACKER_BACKEND=wordpress
# REPLAY_TRACKER_BACKEND=both     # also mirror to Google Sheets during migration

# --- Google Sheets replay tracker (optional mirror) ---
# Sheet: Ganjier Guild Replay Library Tracker
# Get ID from the sheet URL: https://docs.google.com/spreadsheets/d/<ID>/edit
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_WORKSHEET_NAME=Sheet1
# On Windows, optional shortcut path to auto-resolve the spreadsheet ID:
# GOOGLE_SHEETS_SHORTCUT_PATH=h:\Shared drives\Shared Services Administration\07_Projects\Replay Library Migration\Ganjier Guild Replay Library Tracker.gsheet
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# --- Replay YouTube intro (optional) ---
REPLAY_INTRO_ENABLED=false
REPLAY_INTRO_DURATION=5
REPLAY_INTRO_DYNAMIC_TITLE=true
# REPLAY_INTRO_PATH=assets/custom_intro.mp4
# REPLAY_INTRO_LINE1=Ganjier Guild
# REPLAY_INTRO_LINE2=Replay Library
# REPLAY_INTRO_BG_COLOR=0x0f3d24
# REPLAY_INTRO_ACCENT_COLOR=0xc8e6c9

# --- Pipeline ---
TEMP_DIR=/tmp/zoom_pipeline
# On Windows use: TEMP_DIR=%TEMP%\zoom_pipeline
